    public double MutateWeight(double weight, double mutationRange) {
        return weight + weight * (2*mutationRange * m_random.nextDouble() - mutationRange);
    }
    
    public void Mutate(double mutationProbability, double mutationRange) {

        for(Layer layer : m_network.m_layers) {

            for(Neuron neuron : layer.m_neurons) {

                for(int i = 0; i < neuron.m_weights.length; ++i) {
                    if(m_random.nextDouble() < mutationProbability) {
                        neuron.m_weights[i] = MutateWeight(neuron.m_weights[i], mutationRange);
                    }
                }
            }
        }
    }

    public void MakeChild(GeneticAlgorithm p1, GeneticAlgorithm p2, double mutationProbability, double mutationRange) {

        for(int l = 0; l < m_network.m_layers.length; ++l) {
            Layer layer   = m_network.m_layers[l];
            Layer p1Layer = p1.m_network.m_layers[l];
            Layer p2Layer = p2.m_network.m_layers[l];

            for(int n = 0; n < layer.m_neurons.length; ++n) {
                Neuron neuron   = layer.m_neurons[n];
                Neuron p1Neuron = p1Layer.m_neurons[n];
                Neuron p2Neuron = p2Layer.m_neurons[n];
                
                for(int w = 0; w < neuron.m_weights.length; ++w) {

                    // coin flip for parent neuron to inherit from
                    Neuron inheritedNeuron = m_random.nextBoolean() ? p1Neuron : p2Neuron;
                    double inheritedWeight = inheritedNeuron.m_weights[w];
                    
                    neuron.m_weights[w] = (m_random.nextDouble() < mutationProbability) ? MutateWeight(inheritedWeight, mutationRange) : inheritedWeight;
                }
            }
        }
    }

    public static class GameStats {
        double fitness  = 0;
        int gameScore   = 0;
        int gameMoves   = 0;
        int gameMaxTile = 0;

        public void Set(int value) {
            fitness     = value;
            gameScore   = value;
            gameMoves   = value;
            gameMaxTile = value;
        }
    }

    public static class GameWorkerResult {
        GameStats min   = new GameStats();
        GameStats max   = new GameStats();
        GameStats total = new GameStats();

        public GameWorkerResult() {
            Clear();
        }

        public void Clear() {
            min.Set(Integer.MAX_VALUE);
            max.Set(0);
            total.Set(0);
        }

    }

    public static class GameWorker implements Callable<Object> {
        int m_id;
        long m_gameSeed;
        Network m_network;
        GameWorkerResult[] m_results;

        public GameWorker(int id, GameWorkerResult[] results, long gameSeed, Network network) {
            m_id = id;
            m_gameSeed = gameSeed;
            m_network = network;
            m_results = results;
        }

        @Override
        public Object call() {
            Game game = new Game(m_gameSeed);
            GameWorkerResult result = m_results[m_id];

            double fitness = PlayGame(game, m_network, 0, true);

            if(fitness         < result.min.fitness)     result.min.fitness = fitness;
            if(game.m_score    < result.min.gameScore)   result.min.gameScore = game.m_score;
            if(game.m_numMoves < result.min.gameMoves)   result.min.gameMoves = game.m_numMoves;
            if(game.m_maxTile  < result.min.gameMaxTile) result.min.gameMaxTile = game.m_maxTile;

            if(fitness         > result.max.fitness)     result.max.fitness = fitness;
            if(game.m_score    > result.max.gameScore)   result.max.gameScore = game.m_score;
            if(game.m_numMoves > result.max.gameMoves)   result.max.gameMoves = game.m_numMoves;
            if(game.m_maxTile  > result.max.gameMaxTile) result.max.gameMaxTile = game.m_maxTile;

            result.total.fitness+= fitness;
            result.total.gameScore+= game.m_score;
            result.total.gameMoves+= game.m_numMoves;
            result.total.gameMaxTile+= game.m_maxTile;

            return null;
        }
    }

    public static class Demographic {
        Random m_random;

        GeneticAlgorithm[] m_algorithms;
        Integer[] m_algorithmIndices;

        long[] m_trainingSeeds;
        int[] m_batchTrainingIndicies;

        GameWorker[] m_algorithmWorkers;
        GameWorkerResult[] m_algorithmResults;

        public Demographic(long seed, int numAlgorithms, int[] layerWidths, int trainingSize) {

            m_random = new Random(seed);

            // create training data
            m_trainingSeeds = new long[trainingSize];
            m_batchTrainingIndicies = new int[trainingSize];

            for(int i = 0; i < trainingSize; ++i) {
                m_trainingSeeds[i] = m_random.nextLong();
                m_batchTrainingIndicies[i] = i;
            }

            // create algorithms
            m_algorithms       = new GeneticAlgorithm[numAlgorithms];
            m_algorithmIndices = new Integer[numAlgorithms];
            m_algorithmWorkers = new GameWorker[numAlgorithms];


            // TODO: Can this just be part of the GameWorker?
            m_algorithmResults = new GameWorkerResult[numAlgorithms];

            for(int i = 0; i < numAlgorithms; ++i) {

                long algorithmSeed = m_random.nextLong();
                GeneticAlgorithm algorithm = new GeneticAlgorithm(algorithmSeed, layerWidths);
                
                m_algorithms[i] = algorithm;
                m_algorithmIndices[i] = i;
                m_algorithmWorkers[i] = new GameWorker(i, m_algorithmResults, seed, algorithm.m_network);
            }
        }

        protected int computeBatch(int batchSize) {
            // Computes a random batch of 'batchSize' training from m_batchTrainingIndicies
            // the random indices are placed at the end of the m_batchTrainingIndicies array
            // Returns the first index of batch in m_batchTrainingIndicies 
            // Requires 'batchSize' in range [0, m_batchTrainingIndicies.length]
            
            for(int i = 0; i < batchSize; ++i) {
                // sample random trainingIndex without replacement
                int sampleSize          = m_batchTrainingIndicies.length - i;
                int sampleIndex         = m_random.nextInt(sampleSize);
                int sampleTrainingIndex = m_batchTrainingIndicies[sampleIndex];
                
                // swap random sample at the tail of the array
                int tailSampleIndex   = sampleSize - 1;
                int tailTrainingIndex = m_batchTrainingIndicies[tailSampleIndex];
                
                m_batchTrainingIndicies[sampleIndex]     = tailTrainingIndex;
                m_batchTrainingIndicies[tailSampleIndex] = sampleTrainingIndex;
            }
            
            return m_batchTrainingIndicies.length - batchSize;
        }

        public void ScheduleTraining(int gameWorkerOffset, int batchSize) {
            
            int maxBatchSize = m_batchTrainingIndicies.length;
            if(batchSize > maxBatchSize) {
                batchSize = maxBatchSize;
            }
            
            int batchStartIndex = computeBatch(batchSize);

            // configure gameWorkers
            for(int i = 0; i < batchSize; ++i) {
                
                int trainingIndex = m_batchTrainingIndicies[batchStartIndex + i];
                long gameSeed = m_trainingSeeds[trainingIndex];


                // TODO: Make sure this indexes right... alos should m_gameSeed be Integer pointer?
                // GameWorker gameWorker = m_algorithmWorkers[i];
                // gameWorker.m_gameSeed = gameSeed;
            }
        }


        
    }

