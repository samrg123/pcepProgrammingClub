    public static void main(String[] args) {

        Random random = new Random(8264);

        int numThreads          = 14;
        // int numThreads          = 1;
        int outputStride        = 10;

        int numAlgorithms       = 1000;
        // int numEpocs            = 1001;
        int numEpocs            = 201;
        int trainingsPerBatch   = 10;
        
        // int trainingSetSize  = 101;
        // int trainingSetSize  = 100;
        int trainingSetSize  = 3;
        int batchSize        = 2;
        if(batchSize > trainingSetSize) {
            batchSize = trainingSetSize;
        }

        int testDemoSize     = 1;
        int trainingDemoSize = 1;
        int demoDelayMs      = 10;

        double survivalRate     = .1;
        double mutationRate     = .05;
        
        double mutationRange = 1;
        // double mutationProbability = .05;
        double mutationProbability = .05;
        double crossoverMutationProbability = .1;

        // double extinctionRate = .05;
        double extinctionRate = 0;
        double extinctionSurvivalRate = .01;

        double luckRate = .01;


        // int[] layerWidths = {8, 4, 4};
        int[] layerWidths = {8, 8, 4, 4};
        // int[] layerWidths = {16, 10, 10, 10, 4};

        // int[] layerWidths = {8, 6, 4};
        // int[] layerWidths = {16, 8, 4};
        // int[] layerWidths = {10, 8, 6, 4};

        // int[] layerWidths = {32, 4};
        // int[] layerWidths = {4};
        // int[] layerWidths = {8, 4, 4};        
        // int[] layerWidths = {8, 8, 4, 4};
        // int[] layerWidths = {8, 4};
        // int[] layerWidths = {8, 8, 4};
        // int[] layerWidths = {8, 8, 4, 4};
        // int[] layerWidths = {8, 16, 4};
        
        // int[] layerWidths = {16, 10, 10, 10, 4};

        int survivalCount           = (int)(survivalRate * numAlgorithms);
        int mutationCount           = (int)(mutationRate * (numAlgorithms - survivalCount));
        int extinctionSurvivalCount = (int)(extinctionSurvivalRate * numAlgorithms);
        
        int crossoverOffset = survivalCount + mutationCount;

        
        // create training data
        long[] trainingGameSeeds = new long[trainingSetSize];
        for(int i = 0; i < trainingSetSize; ++i) {
            trainingGameSeeds[i] = random.nextLong();
        }

        int[] batchTrainingIndicies = new int[trainingSetSize];
        for(int i = 0; i < trainingSetSize; ++i) {
            batchTrainingIndicies[i] = i;
        }

        // create algorithms
        GeneticAlgorithm[] algorithms = new GeneticAlgorithm[numAlgorithms];
        Integer[] sortedAlgorithmIndices = new Integer[numAlgorithms];

        ExecutorService gameWorkerPool = Executors.newFixedThreadPool(numThreads);
        ArrayList<GameWorker> gameWorkers = new ArrayList<>(numAlgorithms);
        GameWorkerResult[] algorithmResults = new GameWorkerResult[numAlgorithms];        

        for(int i = 0; i < numAlgorithms; ++i) {

            long geneticSeed = random.nextLong();
            GeneticAlgorithm algorithm = new GeneticAlgorithm(geneticSeed, layerWidths);
            
            algorithms[i] = algorithm;
            sortedAlgorithmIndices[i] = i;

            algorithmResults[i] = new GameWorkerResult();
            gameWorkers.add(new GameWorker(i, algorithmResults, 0, algorithm.m_network));
        }


        // create draw window
        NetworkDrawer networkDrawer = new NetworkDrawer("Best Network");

        String[] inputNames = new String[Game.kBoardSize];
        for(int y = 0; y < Game.kBoardHeight; ++y) {
            for(int x = 0; x < Game.kBoardWidth; ++x) {
                inputNames[y*Game.kBoardWidth + x] = x+","+y;
            }
        }
        
        final int kNumDirections = kDirections.length;
        String[] outputNames = new String[kNumDirections];
        Color[] outputColors = new Color[kNumDirections];
        for(int i = 0; i < kNumDirections; ++i) {
            outputNames[i] = kDirections[i].name();
            
            float colorHue = i/(float)kNumDirections;
            outputColors[i] = Color.getHSBColor(colorHue, 1, 1);
        }
        
        // Create Training Graphs
        // Note: +1 for the avg graph
        int numGraphs = trainingSetSize + 1;
        int graphPlotsPerEpoch = numEpocs * trainingsPerBatch;
        double[] trainingFitnesses = new double[numGraphs * graphPlotsPerEpoch];
        NetworkDrawer.GraphPanel[] trainingGraphs = new NetworkDrawer.GraphPanel[numGraphs];
        for(int i = 0; i < numGraphs; ++i) {

            int startIndex = i * graphPlotsPerEpoch;
            int endIndex = startIndex;

            String graphName;
            Color graphColor;

            if(i < trainingSetSize) {
                graphName = "T: " + i; 
                graphColor = Color.GRAY;
            } else {
                graphName = "AVG";
                graphColor = Color.CYAN;
            }

            NetworkDrawer.GraphPanel graphPanel = networkDrawer.AddGraph(graphName, graphPlotsPerEpoch, trainingFitnesses, startIndex, endIndex);

            graphPanel.m_color = graphColor;

            graphPanel.m_xMin = 0;
            graphPanel.m_xMax = graphPlotsPerEpoch;

            graphPanel.m_yMin = Double.MAX_VALUE;
            graphPanel.m_yMax = Double.MIN_VALUE;

            trainingGraphs[i] = graphPanel;
        }
        
        // train algorithms
        for(int epoch = 0; epoch < numEpocs; ++epoch) {

            // compute batch
            for(int i = 0; i < batchSize; ++i) {

                // select random trainingIndex without replacement 
                int sampleSize = trainingSetSize - i;
                int sampleIndex = random.nextInt(sampleSize);
                int newTrainingIndex = batchTrainingIndicies[sampleIndex];
                
                // 'remove' trainingIndex from next batch sample 
                int lastSampleIndex = sampleSize - 1;
                int lastTrainingIndex = batchTrainingIndicies[lastSampleIndex];
                batchTrainingIndicies[sampleIndex] = lastTrainingIndex;
                batchTrainingIndicies[lastSampleIndex] = newTrainingIndex;

                // highlight new batch and unhighlight last batch
                NetworkDrawer.GraphPanel lastBatchGraph = trainingGraphs[lastTrainingIndex];
                NetworkDrawer.GraphPanel newBatchGraph  = trainingGraphs[newTrainingIndex];

                lastBatchGraph.m_color = Color.GRAY;
                newBatchGraph.m_color = Color.WHITE;
            }
            int batchOffset = trainingSetSize - batchSize;

            for(int t = 0; t < trainingsPerBatch; ++t) {
           
                // evaluate batch
                for(int b = 0; b < batchSize; ++b) {
                    
                    int trainingIndex = batchTrainingIndicies[batchOffset + b];
                    long gameSeed = trainingGameSeeds[trainingIndex];

                    // TOOD: replace this with Integer pointer?
                    for(GameWorker gameWorker : gameWorkers) {
                        gameWorker.m_gameSeed = gameSeed;
                    }

                    // evaluate games
                    try {
                        gameWorkerPool.invokeAll(gameWorkers);
                    } catch (InterruptedException e) {
                        e.printStackTrace();
                        System.exit(1);
                    }
                }
                
                // sort algorithms by fitness in descending order
                Arrays.sort(sortedAlgorithmIndices, (Integer index1, Integer index2) -> {
                    double fitness1 = algorithmResults[index1].total.fitness;
                    double fitness2 = algorithmResults[index2].total.fitness;

                    if(fitness1 == fitness2) {
                        fitness1 = algorithmResults[index1].min.fitness;
                        fitness2 = algorithmResults[index2].min.fitness;                    
                    }

                    if(fitness1 == fitness2) {
                        fitness1 = algorithmResults[index1].max.fitness;
                        fitness2 = algorithmResults[index2].max.fitness;                    
                    }                

                    return (fitness1 > fitness2) ? -1 :
                        (fitness1 < fitness2) ?  1 : 0;
                });

                int bestAlgorithmIndex = sortedAlgorithmIndices[0];
                GeneticAlgorithm bestAlgorithm = algorithms[bestAlgorithmIndex];

                // TODO: update training results for tests all tests? 
                //       or should we just the results for the current bactch?
                // TODO: add different population that train on subset of data
                //       plot the performance of the top performing algorithm from each population
                //       against each other population group
                {

                    // TODO: Hacky code just to make sure things are working... make this parallel
                    double totalFitness = 0;
                    for(int i = 0; i < trainingSetSize; ++i) {
                        NetworkDrawer.GraphPanel graph = trainingGraphs[i];
                        long gameSeed = trainingGameSeeds[i];
                        
                        Game game = new Game(gameSeed);
                        double gameFitness = PlayGame(game, bestAlgorithm.m_network, 0, false);
                    
                        if(gameFitness < graph.m_yMin) {
                            graph.m_yMin = gameFitness;
                        }
                    
                        if(gameFitness > graph.m_yMax) {
                            graph.m_yMax = gameFitness;
                        }

                        graph.m_data[graph.m_dataEndIndex++] = gameFitness;
                    
                        totalFitness+= gameFitness;
                    }
                    double avgFitness = (totalFitness != 0) ? (totalFitness / trainingSetSize) : 0;

                    // update avg graph
                    NetworkDrawer.GraphPanel graph = trainingGraphs[trainingSetSize];
                    if(avgFitness < graph.m_yMin) {
                        graph.m_yMin = avgFitness;
                    }
                
                    if(avgFitness > graph.m_yMax) {
                        graph.m_yMax = avgFitness;
                    }

                    graph.m_data[graph.m_dataEndIndex++] = avgFitness;

                    
                    // use a seperate pool for evaluating the training set w/current parent?
                    // or should we just reuse existing pool and swap out results array?

                    // can we just output directly into trainingResults with the correct epoch offset?

                    // evaluate all training games in parallel

                    // add the update the results for the graphs
                }

                boolean shouldPrintStats = (((epoch * trainingsPerBatch + t) % outputStride) == 0);
                if(shouldPrintStats) {
                    GameWorkerResult parent1Results = algorithmResults[bestAlgorithmIndex];

                    double batchNormalizer   = 1.0 / batchSize;
                    double parent1Avgfitness = parent1Results.total.fitness * batchNormalizer;
                    double parent1AvgGame    = parent1Results.total.gameScore * batchNormalizer;
                    double parent1AvgMaxTile = parent1Results.total.gameMaxTile * batchNormalizer;
                    double parent1AvgMoves   = parent1Results.total.gameMoves * batchNormalizer;

                    System.out.printf("[E: %4d - %2d, A: %3d] | AVG: [F: %8.02f, G: %7.02f, T: %7.02f, M: %7.02f] | MIN: [F: %8.02f, G: %5d, T: %4d, M: %4d] | MAX: [F: %8.02f, G: %5d, T: %4d, M: %4d]\n",
                        epoch, t, bestAlgorithmIndex,
                        parent1Avgfitness, parent1AvgGame, parent1AvgMaxTile, parent1AvgMoves,
                        parent1Results.min.fitness, parent1Results.min.gameScore, parent1Results.min.gameMaxTile, parent1Results.min.gameMoves,
                        parent1Results.max.fitness, parent1Results.max.gameScore, parent1Results.max.gameMaxTile, parent1Results.max.gameMoves
                    );
                }

                networkDrawer.SetNetwork(bestAlgorithm.m_network, inputNames, outputNames, outputColors);

                boolean isLastIteration = ((epoch == (numEpocs-1)) && (t == (trainingsPerBatch-1)));
                if(isLastIteration) {
                    // just evaluate the algorithms, don't update them 
                    break;
                }

                boolean isExtinctionEvent = (random.nextDouble() < extinctionRate);

                int numSurvivors;
                if(isExtinctionEvent) {
                    System.out.printf("Epoch: %4d | MASS EXTINCTION TRIGGERED\n", epoch);
                    numSurvivors = extinctionSurvivalCount;
                } else {
                    numSurvivors = survivalCount;
                }
                
                // Note: we skip over modifying survivors 
                for(int i = numSurvivors; i < numAlgorithms; ++i) {
                    int algorithmIndex = sortedAlgorithmIndices[i];
                    GeneticAlgorithm algorithm = algorithms[algorithmIndex];

                    if(isExtinctionEvent) {

                        // replace all nonsurviviors with new networks
                        algorithm.m_network.Reset(algorithm.m_random);

                    } else {

                        boolean isLucky = random.nextDouble() < luckRate;
                        if(isLucky) {

                            // congrats! make a child with the best algorithm
                            algorithm.MakeChild(algorithm, bestAlgorithm, crossoverMutationProbability, mutationRange); 

                        } else if(i < crossoverOffset) {
        
                            // mutate top performing algorithms 
                            algorithm.Mutate(mutationProbability, mutationRange);
        
                        } else {

                            // replace remaining low performing algorithms with children of best algorithms
                            int p1Index = sortedAlgorithmIndices[random.nextInt(numSurvivors)];
                            int p2Index = sortedAlgorithmIndices[random.nextInt(numSurvivors)];

                            GeneticAlgorithm p1 = algorithms[p1Index];
                            GeneticAlgorithm p2 = algorithms[p2Index];

                            algorithm.MakeChild(p1, p2, crossoverMutationProbability, mutationRange);
                            // algorithm.MakeChild(parent1, parent2, crossoverMutationProbability, mutationRange);
                            // algorithm.MakeChild(algorithm, parent1, crossoverMutationProbability, mutationRange);
                        }
                    }
                }    
            
                // clear results for next batch
                for(int i = 0; i < numAlgorithms; ++i) {
                    algorithmResults[i].Clear();
                }
            }
        }

        // show a game using best model
        int algorithmIndex = sortedAlgorithmIndices[0];
        GeneticAlgorithm algorithm = algorithms[algorithmIndex];

        // run ai on last training demos
        for(int i = 0; i < trainingDemoSize; ++i) {
            String title = "Training Demo: "+i;

            // pull game seed from last trained batch which should perform the best
            int trainingIndex = batchTrainingIndicies[trainingSetSize - 1];
            long gameSeed = trainingGameSeeds[trainingIndex];

            PlayDemo(title, algorithm.m_network, gameSeed, demoDelayMs);
        }

        // run ai on new demos
        random.setSeed(9867);
        for(int i = 0; i < testDemoSize; ++i) {
            String title = "Test Demo: "+i;
            PlayDemo(title, algorithm.m_network, random.nextLong(), demoDelayMs);
        }

        return;
    }


    public static void PlayDemo(String title, Network network, long gameSeed, int demoDelayMs) {
        Game game = new Game(gameSeed);
        game.Show(title);
        PlayGame(game, network, demoDelayMs, true);
    }
}